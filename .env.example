# 龙虾出行开放平台 - 环境变量示例
# 复制本文件为 .env.local（本地开发）或在 Vercel 项目 Settings → Environment Variables 配置

# 龙虾开放平台 Token（生产用 rdak_live_ 前缀，测试用 rdak_test_ 前缀）
LONGXIA_TOKEN=rdak_live_xxx

# 接口域名
LONGXIA_HOST=https://api.longxiachuxing.com

# 应用外部访问地址（用于支付返回页 return_url），部署后改成你的域名
NEXT_PUBLIC_BASE_URL=http://localhost:3000
